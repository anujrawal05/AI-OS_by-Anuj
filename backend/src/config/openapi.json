{
  "openapi": "3.0.0",
  "info": {
    "title": "AI-OS v2 Platform API Engine",
    "version": "2.0.0",
    "description": "API documentations for the secure, unified Express backend endpoints servicing the AI-OS platform application client."
  },
  "servers": [
    {
      "url": "/api",
      "description": "Base API Path"
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session_token",
        "description": "Secure HttpOnly session token cookie for authenticated operations."
      }
    }
  },
  "paths": {
    "/auth/signup": {
      "post": {
        "summary": "User Registration",
        "description": "Creates a new unverified user and sends a 6-digit OTP verification code to their email address.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 8 },
                  "name": { "type": "string", "description": "Optional display name" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Signup successful. OTP sent.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Signup successful. Verification OTP sent to email." }
                  }
                }
              }
            }
          },
          "400": { "description": "Validation failed." },
          "409": { "description": "Email already exists." }
        }
      }
    },
    "/auth/verify-otp": {
      "post": {
        "summary": "Verify Email OTP",
        "description": "Verifies the 6-digit email registration OTP code and registers an active session cookie.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "otp"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "otp": { "type": "string", "example": "123456" },
                  "name": { "type": "string", "description": "Optional name update" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account verified and logged in successfully.",
            "headers": {
              "Set-Cookie": {
                "schema": { "type": "string" },
                "description": "HttpOnly session token cookie."
              }
            }
          },
          "401": { "description": "Invalid or expired OTP." }
        }
      }
    },
    "/auth/resend-otp": {
      "post": {
        "summary": "Resend Registration OTP",
        "description": "Generates and sends a new verification OTP code, subject to rate limiting.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": { "type": "string", "format": "email" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OTP resent successfully." },
          "429": { "description": "Rate limit exceeded." }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "User Sign In",
        "description": "Authenticates user via email and password, setting an HttpOnly session cookie on success.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Authenticated successfully." },
          "401": { "description": "Invalid credentials." },
          "403": { "description": "Verification required or account suspended." },
          "429": { "description": "Account locked due to multiple login failures." }
        }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Get Profile Context",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Active session and profile context resolved." },
          "401": { "description": "Unauthorized." }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "Invalidate Current Session",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Logged out successfully." }
        }
      }
    },
    "/auth/logout-all": {
      "post": {
        "summary": "Invalidate All Active Sessions",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Logged out of all active devices successfully." }
        }
      }
    },
    "/auth/forgot-password": {
      "post": {
        "summary": "Forgot Password Request",
        "description": "Generates a password reset token and dispatches a link to the registered email.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": { "type": "string", "format": "email" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "If email exists, reset instructions have been sent." }
        }
      }
    },
    "/auth/reset-password": {
      "post": {
        "summary": "Reset Password Submission",
        "description": "Applies a new password using the cryptographically verified reset token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["token", "password"],
                "properties": {
                  "token": { "type": "string" },
                  "password": { "type": "string", "minLength": 8 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password reset completed successfully." },
          "400": { "description": "Token is invalid or expired." }
        }
      }
    },
    "/auth/update-profile": {
      "post": {
        "summary": "Update Profile Info",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "dateOfBirth": { "type": "string", "format": "date-time" },
                  "gender": { "type": "string", "enum": ["Male", "Female", "Other", "Prefer_Not_To_Say"] },
                  "profession": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Profile updated successfully." }
        }
      }
    },
    "/auth/delete-account": {
      "post": {
        "summary": "Purge User Account",
        "description": "Permanently deletes the active user profile, credentials, preferences, progress records, and invalidates session cookies.",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Account deleted successfully." }
        }
      }
    },
    "/payments/checkout": {
      "post": {
        "summary": "Create Razorpay Order",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["planType"],
                "properties": {
                  "planType": { "type": "string", "enum": ["Premium"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Razorpay order created successfully." }
        }
      }
    },
    "/payments/verify": {
      "post": {
        "summary": "Verify Gateway Payment Signature",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["razorpay_order_id", "razorpay_payment_id", "razorpay_signature"],
                "properties": {
                  "razorpay_order_id": { "type": "string" },
                  "razorpay_payment_id": { "type": "string" },
                  "razorpay_signature": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Payment verified and upgraded successfully." }
        }
      }
    },
    "/payments/coupon": {
      "post": {
        "summary": "Redeem Promo Coupon",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["couponCode"],
                "properties": {
                  "couponCode": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Coupon redeemed successfully." }
        }
      }
    },
    "/payments/key": {
      "get": {
        "summary": "Retrieve Public Gateway Key ID",
        "responses": {
          "200": { "description": "Returned Razorpay Public Key ID." }
        }
      }
    },
    "/strategist/compile": {
      "post": {
        "summary": "Compile Strategic AI Roadmap",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Roadmap matrix generated successfully." }
        }
      }
    },
    "/strategist/chat": {
      "post": {
        "summary": "Conversational AI Strategist Chat",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "AI reply compiled successfully." }
        }
      }
    },
    "/videos": {
      "get": {
        "summary": "List Discovered Videos",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "List of available build and explore video names." }
        }
      }
    },
    "/videos/progress": {
      "get": {
        "summary": "Retrieve Saved Video Progress Logs",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Log array of watched progress parsed." }
        }
      },
      "post": {
        "summary": "Save Video Progress",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["videoFilename", "progressSeconds"],
                "properties": {
                  "videoFilename": { "type": "string" },
                  "progressSeconds": { "type": "number" },
                  "isCompleted": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Progress saved successfully." }
        }
      }
    },
    "/progress/business": {
      "get": {
        "summary": "Retrieve Business Progression Logs",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Logs returned." }
        }
      },
      "post": {
        "summary": "Save Business Progress Step Status",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["stepKey"],
                "properties": {
                  "stepKey": { "type": "string" },
                  "isUnlocked": { "type": "boolean" },
                  "progressPercentage": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Progress recorded." }
        }
      }
    },
    "/bookmarks": {
      "get": {
        "summary": "Get Saved Bookmarks",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "List of bookmarked tools." }
        }
      },
      "post": {
        "summary": "Toggle Bookmark Status",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["toolId"],
                "properties": {
                  "toolId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Bookmark status toggled." }
        }
      }
    },
    "/notifications": {
      "get": {
        "summary": "Get User Notifications Inbox",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "List of user notifications." }
        }
      }
    },
    "/notifications/{id}/read": {
      "post": {
        "summary": "Mark Notification as Read",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Marked successfully." }
        }
      }
    },
    "/support/ticket": {
      "post": {
        "summary": "Open Support Ticket",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["subject", "message"],
                "properties": {
                  "subject": { "type": "string" },
                  "message": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Ticket created." }
        }
      }
    },
    "/admin/stats": {
      "get": {
        "summary": "Retrieve Admin Dashboard Performance Stats",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Stats compiled." }
        }
      }
    },
    "/admin/users": {
      "get": {
        "summary": "Paginated User Directory query",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Paginated users list returned." }
        }
      }
    },
    "/admin/users/plan": {
      "post": {
        "summary": "Manual Plan Override",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Overridden successfully." }
        }
      }
    },
    "/admin/users/suspend": {
      "post": {
        "summary": "Toggle User Account Suspension",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Suspension toggled." }
        }
      }
    },
    "/admin/broadcast": {
      "post": {
        "summary": "Dispatch Notification Broadcast",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "201": { "description": "Broadcast sent." }
        }
      }
    },
    "/admin/audit": {
      "get": {
        "summary": "Query Operational Audit Logs",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Logs resolved." }
        }
      }
    },
    "/admin/health": {
      "get": {
        "summary": "System Health Diagnostics",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Diagnostics compiled successfully." }
        }
      }
    }
  }
}
