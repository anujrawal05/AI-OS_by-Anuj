datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // uncomment next line if you use Prisma <5.10
  // directUrl = env("DATABASE_URL_UNPOOLED")
}

generator client {
  provider      = "prisma-client-js"
  output        = "../../node_modules/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

enum UserRole {
  Admin
  User
  Support
}

enum UserGender {
  Male
  Female
  Other
  Prefer_Not_To_Say
}

enum PlanType {
  Free
  Premium
  Trial
}

enum SubscriptionStatus {
  Active
  Canceled
  Past_Due
  Expired
}

enum PaymentProvider {
  Razorpay
}

enum PaymentStatus {
  Pending
  Completed
  Failed
}

enum TransactionType {
  Credit
  Charge
}

enum AIActionType {
  Compile
  Chat
}

enum NotificationType {
  System
  Update
  Billing
}

enum TicketStatus {
  Open
  In_Progress
  Closed
}

enum TicketPriority {
  Low
  Medium
  High
}

enum ThemeMode {
  Dark
  Light
}

enum LanguageMode {
  English
  Hindi
  Hinglish
}

model User {
  id                  String                   @id @default(uuid()) @db.Uuid
  email               String                   @unique
  passwordHash        String                   @map("password_hash")
  role                UserRole                 @default(User)
  isVerified          Boolean                  @default(false) @map("is_verified")
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")
  
  profile             Profile?
  sessions            Session[]
  emailVerifications  EmailVerification[]
  passwordResets      PasswordReset[]
  subscription        Subscription?
  payments            Payment[]
  transactions        Transaction[]
  trial               Trial?
  promptUsage         PromptUsage?
  aiHistory           AIHistory[]
  notifications       Notification[]
  supportTickets      SupportTicket[]
  preferences         UserPreference?
  videoProgress       VideoProgress[]
  businessProgress    BusinessProgress[]
  bookmarks           Bookmark[]
  adminLogs           AdminLog[]
  auditLogs           AuditLog[]

  // Lockout / Security Fields
  failedLoginAttempts Int                      @default(0) @map("failed_login_attempts")
  lockoutUntil        DateTime?                @map("lockout_until")
  suspended           Boolean                  @default(false)

  @@map("users")
}

model Profile {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @unique @map("user_id") @db.Uuid
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  dateOfBirth DateTime   @map("date_of_birth")
  gender      UserGender @default(Prefer_Not_To_Say)
  profession  String
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("profiles")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String   @unique @map("session_token")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("sessions")
}

model EmailVerification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  isUsed    Boolean  @default(false) @map("is_used")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("email_verifications")
}

model PasswordReset {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resetToken String   @unique @map("reset_token")
  isUsed     Boolean  @default(false) @map("is_used")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("password_resets")
}

model Subscription {
  id                  String             @id @default(uuid()) @db.Uuid
  userId              String             @unique @map("user_id") @db.Uuid
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                PlanType           @default(Free)
  status              SubscriptionStatus @default(Expired)
  currentPeriodStart  DateTime           @map("current_period_start")
  currentPeriodEnd    DateTime           @map("current_period_end")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  payments            Payment[]

  @@map("subscriptions")
}

model Payment {
  id                 String          @id @default(uuid()) @db.Uuid
  userId             String          @map("user_id") @db.Uuid
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId     String          @map("subscription_id") @db.Uuid
  subscription       Subscription    @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  provider           PaymentProvider @default(Razorpay)
  amount             Decimal         @db.Decimal(12, 2)
  currency           String          @default("INR")
  gatewayOrderId     String          @unique @map("gateway_order_id")
  gatewayPaymentId   String?         @unique @map("gateway_payment_id")
  gatewaySignature   String?         @map("gateway_signature")
  status             PaymentStatus   @default(Pending)
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  transactions       Transaction[]

  @@index([userId])
  @@index([status])
  @@map("payments")
}

model Transaction {
  id          String          @id @default(uuid()) @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentId   String?         @map("payment_id") @db.Uuid
  payment     Payment?        @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType
  description String
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([userId])
  @@map("transactions")
}

model Trial {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt      DateTime @map("started_at")
  expiresAt      DateTime @map("expires_at")
  daysRemaining  Int      @default(3) @map("days_remaining")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("trials")
}

model PromptUsage {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @unique @map("user_id") @db.Uuid
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptCount    Int       @default(0) @map("prompt_count")
  limitReachedAt DateTime? @map("limit_reached_at")
  resetAt        DateTime  @map("reset_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("prompt_usages")
}

model AIHistory {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     AIActionType
  inputData  Json         @map("input_data")
  outputData Json         @map("output_data")
  createdAt  DateTime     @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("ai_history")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType @default(System)
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model SupportTicket {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  message   String
  status    TicketStatus   @default(Open)
  priority  TicketPriority @default(Medium)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model UserPreference {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @unique @map("user_id") @db.Uuid
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme     ThemeMode    @default(Dark)
  language  LanguageMode @default(English)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("user_preferences")
}

model VideoProgress {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoFilename  String   @map("video_filename")
  progressSeconds Decimal  @default(0.00) @map("progress_seconds") @db.Decimal(10, 2)
  isCompleted    Boolean  @default(false) @map("is_completed")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([userId, videoFilename])
  @@map("video_progress")
}

model BusinessProgress {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepKey            String   @map("step_key")
  isUnlocked         Boolean  @default(false) @map("is_unlocked")
  progressPercentage Int      @default(0) @map("progress_percentage")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([userId, stepKey])
  @@map("business_progress")
}

model Bookmark {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolId    String   @map("tool_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, toolId])
  @@map("bookmarks")
}

model AdminLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  actionName String   @map("action_name")
  details    Json
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("admin_logs")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
