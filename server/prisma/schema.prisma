datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

model User {
  id                 Int                      @id @default(autoincrement())
  email              String                   @unique
  passwordHash       String                   @map("password_hash")
  fullName           String?                  @map("full_name")
  gender             String?
  profession         String?
  dateOfBirth        String?                  @map("date_of_birth")
  isVerified         Boolean                  @default(false) @map("is_verified")
  createdAt          DateTime                 @default(now()) @map("created_at")
  subscription       Subscription?
  payments           Payment[]
  usageLimit         UsageLimit?
  resetTokens        PasswordResetToken[]
  verificationTokens EmailVerificationToken[]
  usageLogs          UsageLog[]
  
  // Security lockouts, suspensions, & session audits
  failedLoginAttempts Int                    @default(0) @map("failed_login_attempts")
  lockoutUntil        DateTime?              @map("lockout_until")
  suspended           Boolean                @default(false)
  sessions            UserSession[]
  auditLogs           AuditLog[]
  
  // Launch readiness extensions
  notifications       Notification[]
  supportTickets      SupportTicket[]
  preferences         UserPreference?

  @@map("users")
}

model Subscription {
  userId         Int       @id @map("user_id")
  planType       String    @default("Basic") @map("plan_type")
  status         String    @default("trial")
  trialStartedAt DateTime? @map("trial_started_at")
  trialExpiresAt DateTime? @map("trial_expires_at")
  trialUsed      Boolean   @default(false) @map("trial_used")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Custom Subscription tracking
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")
  renewalStatus  String?   @default("active") @map("renewal_status")

  @@map("subscriptions")
}

model Payment {
  id                 Int      @id @default(autoincrement())
  userId             Int      @map("user_id")
  razorpayOrderId    String   @map("razorpay_order_id")
  razorpayPaymentId  String   @map("razorpay_payment_id")
  amount             Int
  status             String
  createdAt          DateTime @default(now()) @map("created_at")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Custom transactional billing details
  paymentStatus      String?  @map("payment_status")
  invoiceNumber      String?  @map("invoice_number")
  couponUsed         String?  @map("coupon_used")

  @@map("payments")
}

model UsageLimit {
  userId      Int      @id @map("user_id")
  promptCount Int      @default(0) @map("prompt_count")
  resetDate   DateTime @default(now()) @map("reset_date")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("usage_limits")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model UsageLog {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  actionType  String   @map("action_type")
  promptCount Int      @default(1) @map("prompt_count")
  details     String?
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("usage_logs")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    Int      @map("user_id")
  token     String   @unique
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  actionType String   @map("action_type")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  details    String?
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model RateLimit {
  id       Int      @id @default(autoincrement())
  key      String   @unique
  points   Int      @default(0)
  expireAt DateTime @map("expire_at")

  @@map("rate_limits")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model SupportTicket {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  title         String
  description   String
  type          String   @default("bug")
  status        String   @default("open")
  attachmentUrl String?  @map("attachment_url")
  adminNotes    String?  @map("admin_notes")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("support_tickets")
}

model UserPreference {
  userId        Int     @id @map("user_id")
  emailPromo    Boolean @default(true) @map("email_promo")
  emailBilling  Boolean @default(true) @map("email_billing")
  emailSecurity Boolean @default(true) @map("email_security")
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}
