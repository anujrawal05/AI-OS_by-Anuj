# Production Environment Configuration
# DO NOT hardcode backend URL - use environment variables in Vercel dashboard
# Backend will be injected via:
# 1. REACT_APP_BACKEND_URL environment variable (Vercel)
# 2. Meta tag at build time
# 3. Window variable injected by build script

BACKEND_URL=INJECT_FROM_VERCEL_ENV
NODE_ENV=production
REACT_APP_BACKEND_URL=INJECT_FROM_VERCEL_ENV
