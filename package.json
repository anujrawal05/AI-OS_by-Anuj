  "description": "AI-OS Execution Platform - Unified Frontend and Vercel Serverless Backend",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "npm run vercel-build",
    "vercel-build": "node scripts/vercel-build.js",
    "dev:backend": "cd backend && set PORT=3001 && npm run dev",
    "dev:frontend": "npx http-server -p 3000 -c-1",
    "dev": "npx concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "test": "echo 'Tests would run here'",
    "setup:dev": "echo 'Make sure backend is running at http://localhost:8080'"
  },
  "keywords": ["ai", "os", "intelligence", "dynamic-backend"],
