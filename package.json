{
  "name": "ai-os-platform",
  "version": "2.0.0",
  "description": "AI-OS Execution Platform - Unified Frontend and Vercel Serverless Backend",
  "scripts": {
    "vercel-build": "prisma generate --schema=backend/prisma/schema.prisma",
    "dev:backend": "cd backend && set PORT=3001 && npm run dev",
    "dev:frontend": "npx http-server -p 3000 -c-1",
    "dev": "npx concurrently \"npm:dev:backend\" \"npm:dev:frontend\""
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "razorpay": "^2.9.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "prisma": "^5.22.0",
    "concurrently": "^8.2.0"
  }
}
