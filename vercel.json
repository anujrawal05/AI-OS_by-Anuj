{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/backend/:path*",
      "destination": "/404"
    },
    {
      "source": "/package.json",
      "destination": "/404"
    },
    {
      "source": "/package-lock.json",
      "destination": "/404"
    },
    {
      "source": "/vercel.json",
      "destination": "/404"
    }
  ]
}
