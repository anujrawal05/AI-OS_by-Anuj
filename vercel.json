{
  "version": 2,
  "buildCommand": "npx prisma generate --schema=backend/prisma/schema.prisma",
  "outputDirectory": ".",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs22.x",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}