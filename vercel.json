{
  "buildCommand": "npm run vercel-build",
  "functions": {
    "api/index.js": {
      "runtime": "@vercel/node"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/backend/:path*",
      "destination": "/404"
    },
    {
      "source": "/package.json",
      "destination": "/404"
    },
    {
      "source": "/package-lock.json",
      "destination": "/404"
    },
    {
      "source": "/vercel.json",
      "destination": "/404"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    }
  ]
}
