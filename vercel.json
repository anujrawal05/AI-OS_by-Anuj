{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/backend/(.*)",
      "dest": "/404"
    },
    {
      "src": "/package.json",
      "dest": "/404"
    },
    {
      "src": "/package-lock.json",
      "dest": "/404"
    },
    {
      "src": "/vercel.json",
      "dest": "/404"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "handle": "filesystem"
    }
  ]
}
