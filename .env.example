PORT=8080
NODE_ENV=production

# PostgreSQL (Neon / Supabase / Railway Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_64char_hex_secret_here

# Email (Brevo — https://app.brevo.com/)
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=your@email.com
EMAIL_FROM_NAME=AI-OS

# Frontend URL (Vercel deployment URL — used for password-reset email links)
FRONTEND_URL=https://your-app.vercel.app

# Backend URL (used for CORS + api-base-url meta tag in index.html)
BACKEND_URL=https://your-backend.up.railway.app

# Razorpay (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_SECRET_KEY=your_razorpay_secret_key

# Coupon codes (comma-separated). Rotate without code redeploy.
COUPON_CODES=VIP2026,LAUNCH50

# OpenRouter AI API (optional — mock fallback used if blank)
OPENROUTER_API_KEY=
