# ============================================
# BACKEND CONFIGURATION
# ============================================
# Choose ONE method for backend URL configuration:
#
# Method 1 (Recommended for Vercel):
#   - Go to Vercel Dashboard → Settings → Environment Variables
#   - Add: REACT_APP_BACKEND_URL=https://your-backend.example.com
#
# Method 2 (Development):
#   - For local development: http://localhost:8080
#   - Auto-detected when running on localhost
#
# Method 3 (Meta tag injection):
#   - Backend URL can be injected via HTML meta tag at build time
#   - See modules/backendConfig.js for implementation

BACKEND_URL=INJECT_FROM_VERCEL_ENV
REACT_APP_BACKEND_URL=INJECT_FROM_VERCEL_ENV
NODE_ENV=production

# ============================================
# DATABASE (Optional - only if you use a database)
# ============================================
DATABASE_URL=your_database_url_here
MONGO_URI=your_mongodb_connection_string

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=7d

# ============================================
# API KEYS (Only if integrated)
# ============================================
OPENAI_API_KEY=sk-your-openai-key
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_PUBLIC_KEY=pk_live_your_stripe_key

# ============================================
# EMAIL SERVICE (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ============================================
# SECURITY & CORS
# ============================================
CORS_ORIGIN=https://ai-os-powerd-by-ar-labs.vercel.app
SESSION_SECRET=your_session_secret_key

# ============================================
# FILE UPLOAD
# ============================================
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log
SENTRY_DSN=your_sentry_dsn_for_error_tracking

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_AUTH=true
ENABLE_PAYMENTS=true
ENABLE_NOTIFICATIONS=true
ENABLE_BACKEND_FALLBACK=true
