# =============================================================================
# AI-OS Backend Environment Variables
# =============================================================================
# PRODUCTION (Vercel): Set ALL of these in:
#   Vercel Dashboard → Your Project → Settings → Environment Variables
#   Select: Production + Preview + Development
#
# LOCAL DEV: Copy this file to .env and fill in values.
# NEVER commit .env to git — it is listed in .gitignore.
# =============================================================================

# --- Server ---
PORT=8080
NODE_ENV=production

# --- PostgreSQL (Neon / Supabase / Railway Postgres) ---
# Get from: https://console.neon.tech/ → Connection string (pooled, PgBouncer)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true

# --- JWT Secret ---
# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# CRITICAL: Rotate this if it was ever committed to git.
JWT_SECRET=your_128char_hex_secret_here

# --- Email (Brevo — https://app.brevo.com/) ---
# Get from: Brevo dashboard → SMTP & API → API Keys
BREVO_API_KEY=your_brevo_api_key_here
EMAIL_FROM=your@email.com
EMAIL_FROM_NAME=AI-OS

# --- Frontend URL (Vercel deployment URL) ---
# Used for password-reset email links — MUST match your actual Vercel URL
FRONTEND_URL=https://ai-os-powerd-by-ar-labs.vercel.app

# --- Backend URL (if hosting backend separately on Railway/Render) ---
# If using Vercel Serverless (monorepo), leave this blank.
# If hosting backend on Railway: set to https://your-backend.up.railway.app
BACKEND_URL=

# --- Razorpay (https://dashboard.razorpay.com/app/keys) ---
# Use Live keys (rzp_live_*) for production. Test keys only for local dev.
# CRITICAL: Also update <meta name="razorpay-key-id"> in index.html and aios_buisness.html.
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_SECRET_KEY=your_razorpay_live_secret_key

# --- CORS (optional extra origins) ---
# Comma-separated list of additional allowed origins beyond the defaults.
# Default allowed: localhost:8080, localhost:3000, ai-os-powerd-by-ar-labs.vercel.app
CORS_ALLOWED_ORIGINS=

# --- Coupon codes (comma-separated) ---
# Rotate without code redeploy by updating this env var.
COUPON_CODES=VIP2026,LAUNCH50

# --- OpenRouter AI API (optional — mock fallback used if blank) ---
OPENROUTER_API_KEY=

# =============================================================================
# VERCEL REQUIRED ENV VARS CHECKLIST (must be set for production launch):
# =============================================================================
# ✅ NODE_ENV=production
# ✅ DATABASE_URL=<your-neon-connection-string>
# ✅ JWT_SECRET=<strong-random-hex>
# ✅ BREVO_API_KEY=<your-brevo-key>
# ✅ RAZORPAY_KEY_ID=rzp_live_*
# ✅ RAZORPAY_SECRET_KEY=<live-secret>
# ✅ FRONTEND_URL=https://ai-os-powerd-by-ar-labs.vercel.app
# =============================================================================
